<% content_for :title, "Nova entrevista — InterviewSim" %>

<div class="mx-auto max-w-xl">
  <%= link_to interview_sessions_path, class: "text-xs text-zinc-500 hover:text-zinc-700" do %>
    ← Voltar
  <% end %>

  <div class="mt-4 rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
    <h1 class="text-lg font-semibold text-zinc-900">Configurar entrevista</h1>
    <p class="mt-1 text-sm text-zinc-500">A IA vai conduzir 5 a 8 perguntas calibradas pro cargo e nível.</p>

    <%= form_with url: interview_sessions_path, method: :post, class: "mt-6 space-y-4" do |form| %>
      <div>
        <label for="role" class="text-sm font-medium text-zinc-700">Cargo</label>
        <input type="text" name="role" id="role" required autofocus placeholder="ex: Backend Engineer, Product Designer, Tech Lead"
               class="mt-1 block w-full rounded-md border border-zinc-200 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
      </div>

      <div>
        <label class="text-sm font-medium text-zinc-700">Nível</label>
        <div class="mt-2 grid grid-cols-5 gap-2">
          <% @levels.each_with_index do |level, idx| %>
            <label class="flex cursor-pointer items-center justify-center rounded-md border border-zinc-200 px-2 py-2 text-xs capitalize text-zinc-700 has-checked:border-indigo-600 has-checked:bg-indigo-50 has-checked:text-indigo-700">
              <input type="radio" name="level" value="<%= level %>" class="sr-only" <%= "checked" if idx.zero? %>>
              <%= level %>
            </label>
          <% end %>
        </div>
      </div>

      <div class="flex items-center justify-end gap-2 border-t border-zinc-100 pt-4">
        <%= link_to "Cancelar", interview_sessions_path,
              class: "rounded-md px-3 py-2 text-sm text-zinc-600 hover:bg-zinc-50" %>
        <%= form.submit "Iniciar entrevista",
              class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
      </div>
    <% end %>
  </div>
</div>
