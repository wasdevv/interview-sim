<% content_for :title, "#{@session.role} — InterviewSim" %>

<%= turbo_stream_from [ @session, :stream ] %>

<div class="flex items-start justify-between gap-3">
  <div class="min-w-0">
    <%= link_to interview_sessions_path, class: "text-xs text-zinc-500 hover:text-zinc-700" do %>
      ← Voltar
    <% end %>
    <h1 class="mt-1 truncate text-xl font-semibold tracking-tight text-zinc-900">
      <%= @session.role %>
    </h1>
    <p class="text-xs text-zinc-500"><%= @session.level.capitalize %> · <%= l(@session.created_at, format: :short) %></p>
  </div>

  <div id="<%= dom_id(@session, :status) %>" class="shrink-0">
    <%= render "interview_sessions/status", session: @session %>
  </div>
</div>

<div class="mt-6 rounded-2xl border border-zinc-200 bg-white">
  <ul class="flex max-h-[60vh] flex-col gap-3 overflow-y-auto p-4" id="<%= dom_id(@session, :messages) %>">
    <% @messages.each do |message| %>
      <%= render "interview_messages/bubble", message: message %>
    <% end %>
  </ul>

  <% if @session.status_running? %>
    <div class="border-t border-zinc-200 p-3">
      <%= form_with url: interview_session_messages_path(@session), method: :post,
            data: { controller: "message-form", action: "submit->message-form#submit keydown->message-form#handleKeydown" },
            class: "flex items-end gap-2" do |form| %>
        <%= form.text_area "message[content]",
              rows: 1, required: true,
              placeholder: "Sua resposta…",
              data: { "message-form-target": "input" },
              class: "flex-1 resize-none rounded-md border border-zinc-200 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        <%= form.button type: :submit,
              class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" do %>
          Enviar
        <% end %>
      <% end %>
      <p class="mt-2 px-1 text-xs text-zinc-400">Enter envia · Shift+Enter quebra linha</p>
    </div>
  <% else %>
    <div class="border-t border-zinc-200 p-3 text-center text-xs text-zinc-500">
      Entrevista encerrada. <%= link_to "Iniciar nova", new_interview_session_path, class: "text-indigo-600 hover:underline" %>
    </div>
  <% end %>
</div>

<div class="mt-4 flex items-center justify-end gap-4">
  <% if @session.status_running? %>
    <%= button_to "Encerrar agora", abandon_interview_session_path(@session), method: :patch,
          form: { data: { turbo_confirm: "Encerrar essa entrevista?" } },
          class: "text-xs text-zinc-500 underline hover:text-rose-600" %>
  <% end %>
  <%= button_to "Apagar entrevista", interview_session_path(@session), method: :delete,
        form: { data: { turbo_confirm: "Apagar essa entrevista? Não dá pra desfazer." } },
        class: "text-xs text-rose-600 underline hover:text-rose-700" %>
</div>
