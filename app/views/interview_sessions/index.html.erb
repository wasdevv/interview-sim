<% content_for :title, "Suas entrevistas — InterviewSim" %>

<div class="flex items-start justify-between gap-3">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">Suas entrevistas</h1>
    <p class="mt-1 text-sm text-zinc-500">Pratique antes da próxima entrevista real.</p>
  </div>
  <%= link_to new_interview_session_path,
        class: "inline-flex items-center gap-1.5 rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500" do %>
    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/>
    </svg>
    Nova entrevista
  <% end %>
</div>

<% if @sessions.empty? %>
  <div class="mt-10 rounded-2xl border border-dashed border-zinc-300 bg-white p-10 text-center">
    <p class="text-sm text-zinc-500">Nada por aqui ainda — crie sua primeira entrevista.</p>
  </div>
<% else %>
  <ul class="mt-6 divide-y divide-zinc-200 overflow-hidden rounded-2xl border border-zinc-200 bg-white">
    <% @sessions.each do |s| %>
      <li class="flex items-center gap-4 px-4 py-3 hover:bg-zinc-50">
        <%= link_to interview_session_path(s), class: "flex min-w-0 flex-1 items-center justify-between gap-4" do %>
          <div class="min-w-0">
            <p class="truncate text-sm font-medium text-zinc-900"><%= s.role %></p>
            <p class="mt-0.5 text-xs text-zinc-500">
              <%= s.level.capitalize %> · <%= s.messages.size %> mensagens · <%= l(s.created_at, format: :short) %>
            </p>
          </div>
          <span class="rounded-full px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide <%= status_badge_class(s) %>">
            <%= status_label(s) %>
          </span>
        <% end %>
        <%= button_to interview_session_path(s),
              method: :delete,
              form: { data: { turbo_confirm: "Apagar essa entrevista? Não dá pra desfazer." } },
              class: "rounded-md p-2 text-zinc-400 hover:bg-rose-50 hover:text-rose-600",
              title: "Apagar" do %>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6h14zM10 11v6M14 11v6"/>
          </svg>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>
