<% if session.feedback.present? %>
  <div class="mt-6 rounded-2xl border border-indigo-200 bg-indigo-50/40 p-6">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h2 class="text-base font-semibold text-zinc-900">Feedback da entrevista</h2>
        <p class="mt-0.5 text-xs text-zinc-500">
          Gerado em <%= l(session.feedback_generated_at, format: :short) %>
          · backend: <%= Interviewer::Claude.backend.name.demodulize.downcase %>
        </p>
      </div>
      <%= button_to "Regerar", feedback_interview_session_path(session), method: :post,
            form: { data: { turbo_confirm: "Substituir o feedback atual?" } },
            class: "rounded-md border border-zinc-200 bg-white px-2.5 py-1 text-xs text-zinc-600 hover:bg-zinc-50" %>
    </div>
    <div class="mt-4 whitespace-pre-line text-sm leading-relaxed text-zinc-800">
      <%= session.feedback %>
    </div>
  </div>
<% elsif !session.status_running? %>
  <div class="mt-6 flex items-center justify-between gap-3 rounded-2xl border border-dashed border-zinc-300 bg-white p-6">
    <div>
      <p class="text-sm font-medium text-zinc-900">Sem feedback ainda</p>
      <p class="mt-0.5 text-xs text-zinc-500">
        Clica pra gerar agora — leva alguns segundos.
      </p>
    </div>
    <%= button_to "Gerar feedback", feedback_interview_session_path(session), method: :post,
          class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
  </div>
<% end %>
